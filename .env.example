# ---- LLM provider (both are FREE) ----
# Option A (recommended): Groq — instant Llama 3.1, generous free tier
#   Get a key at https://console.groq.com  (no credit card)
LLM_PROVIDER=groq
GROQ_API_KEY=

# Option B: Hugging Face Inference — free token
#   Get one at https://huggingface.co/settings/tokens
# LLM_PROVIDER=huggingface
# HF_TOKEN=

# ---- Security ----
JWT_SECRET=replace-with-a-long-random-string
